{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Hesham's build C Project",
            "type": "process",
            "command": "C:/Program Files/x86_64-8.1.0-release-posix-seh-rt_v6-rev0/mingw64/bin/gcc.exe",
            "args": [
                "-g",
                "-Wall",
                "-Wextra",
                "-I",
                "${workspaceFolder}/include",
                "${workspaceFolder}/src/device_info.c",
                "${workspaceFolder}/src/event_manager.c",
                "${workspaceFolder}/src/led_controller.c",
                "${workspaceFolder}/src/main.c",
                "-o",
                "${workspaceFolder}/build/program/output.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Hesham's Build Unit Tests",
            "type": "process",
            "command": "C:/Program Files/x86_64-8.1.0-release-posix-seh-rt_v6-rev0/mingw64/bin/gcc.exe",
            "args": [
                "-g",
                "-Wall",
                "-Wextra",

                "-I",
                "${workspaceFolder}/include",

                "-I",
                "${workspaceFolder}/tests/unity_framework",

                "${workspaceFolder}/tests/unity_framework/unity.c",
                "${workspaceFolder}/tests/unit_tests/test_event_manager.c",

                "-o",
                "${workspaceFolder}/build/tests/unit_tests.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        /*
             Task to build the Unit tests and then run them. That's why there is no
              need to build before ruuning this task.
        */
        {
            "label": "Hesham's Run Unit Tests",
            "type": "process",
            "command": "${workspaceFolder}/build/tests/unit_tests.exe",
            "dependsOn": [
                "Hesham's Build Unit Tests"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}