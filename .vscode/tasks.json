{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Hesham's build C Project",
            "type": "process",
            "command": "C:/Program Files/x86_64-8.1.0-release-posix-seh-rt_v6-rev0/mingw64/bin/gcc.exe",
            "args": [
                "-g",
                "-Wall",
                "-Wextra",
                "-I",
                "${workspaceFolder}/include",
                "${workspaceFolder}/src/math.c",
                "${workspaceFolder}/src/main.c",
                "-o",
                "${workspaceFolder}/build/output.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Hesham's Run Unit Tests",
            "type": "shell",
            "command": "& 'C:/Program Files/x86_64-8.1.0-release-posix-seh-rt_v6-rev0/mingw64/bin/gcc.exe' -g -Wall -Wextra -I '${workspaceFolder}/include' '${workspaceFolder}/src/math.c' '${workspaceFolder}/tests/test_math.c' -o '${workspaceFolder}/build/tests.exe'; if ($?) { & '${workspaceFolder}/build/tests.exe' }",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}